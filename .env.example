# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Site URL (required for email confirmation links and desktop app updates)
NEXT_PUBLIC_SITE_URL=https://lhw-six.vercel.app

# Groq (desktop pet AI — must be NEXT_PUBLIC_ for Tauri static export)
NEXT_PUBLIC_GROQ_API_KEY=your-groq-api-key

# Desktop app export signing (local only — path to private key file)
# TAURI_SIGNING_PRIVATE_KEY_PATH=src-tauri/.updater/private.key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Optional: seed profile script
# SEED_EMAIL=you@example.com
# SEED_PASSWORD=your-password
